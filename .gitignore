# Cloud Android Runner — Git Ignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Data
/data/*
!/data/.gitkeep

# Logs
*.log
/data/logs/*

# Screenshots
/data/screenshots/*
*.png
*.jpg

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Docker
.dockerignore

# OS
.DS_Store
Thumbs.db

# Temp
/tmp/
